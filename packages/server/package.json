{
  "name": "@boringos-crm/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && pnpm postbuild",
    "postbuild": "node -e \"const{cpSync}=require('node:fs');cpSync('src/skills','dist/skills',{recursive:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@boringos/agent": "link:../../../boringos-framework/packages/@boringos/agent",
    "@boringos/module-sdk": "link:../../../boringos-framework/packages/@boringos/module-sdk",
    "@boringos/connector-google": "link:../../../boringos-framework/packages/@boringos/connector-google",
    "@boringos/connector-slack": "link:../../../boringos-framework/packages/@boringos/connector-slack",
    "@boringos/core": "link:../../../boringos-framework/packages/@boringos/core",
    "@boringos/db": "link:../../../boringos-framework/packages/@boringos/db",
    "@boringos/shared": "link:../../../boringos-framework/packages/@boringos/shared",
    "@boringos-crm/shared": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3"
  }
}

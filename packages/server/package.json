{
  "name": "@boringos-crm/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "GPL-3.0-or-later",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && pnpm postbuild",
    "postbuild": "node -e \"const{cpSync}=require('node:fs');cpSync('src/skills','dist/skills',{recursive:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@boringos/agent": "^0.1.17",
    "@boringos/module-sdk": "^0.10.0",
    "@boringos/connector-google": "^0.2.8",
    "@boringos/connector-slack": "^0.2.8",
    "@boringos/core": "^0.2.5",
    "@boringos/db": "^0.1.9",
    "@boringos/shared": "^0.1.8",
    "@boringos-crm/shared": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
